# Server
PORT=8990
NODE_ENV=development
# Public URL of the addon, used to build the personalized URLs and the magic-links.
# Locally: http://127.0.0.1:8990 — on Render: https://cinepals.onrender.com
PUBLIC_URL=http://127.0.0.1:8990

# Database (Render Postgres or local)
DATABASE_URL=postgresql://postgres:postgres@localhost:5555/cinepals?schema=public

# Secret for signing session JWTs (long random string)
JWT_SECRET=change-me-to-a-long-random-string

# TMDB — https://www.themoviedb.org/settings/api  (v3 API key)
TMDB_API_KEY=

# Transactional email (optional). If RESEND_API_KEY is empty, emails go to SMTP_URL
# (the local Mailpit trap) when set, otherwise they're printed to the console.
RESEND_API_KEY=
EMAIL_FROM="Cinepals <noreply@example.com>"

# Local mail trap (Mailpit). Captures dev emails — inbox at http://127.0.0.1:8025.
# Start it with `just mail-up` (or `just dev` / `just up`, which include it).
SMTP_URL=smtp://127.0.0.1:1025

# Bearer token protecting POST /internal/run-digest (the daily suggestion digest).
# Must match the CRON_SECRET stored in the scheduler (GitHub Actions). Long random string.
CRON_SECRET=change-me-to-a-long-random-string
