# Server
PORT=8990
NODE_ENV=development
# Public URL of the addon, used to build the personalized URLs and the magic-links.
# Locally: http://127.0.0.1:8990 — on Render: https://stremio-friends.onrender.com
PUBLIC_URL=http://127.0.0.1:8990

# Database (Render Postgres or local)
DATABASE_URL=postgresql://postgres:postgres@localhost:5555/stremio_friends?schema=public

# Secret for signing session JWTs (long random string)
JWT_SECRET=change-me-to-a-long-random-string

# TMDB — https://www.themoviedb.org/settings/api  (v3 API key)
TMDB_API_KEY=

# Transactional email (optional). If RESEND_API_KEY is empty, emails are printed to the console (dev).
RESEND_API_KEY=
EMAIL_FROM="Stremio Friends <noreply@example.com>"
