# Image for local development (hot-reload via tsx watch).
FROM node:20-alpine

# Prisma on Alpine requires openssl for the query engine.
RUN apk add --no-cache openssl

# Enable pnpm via corepack (version pinned by package.json "packageManager").
RUN corepack enable

WORKDIR /app

# Install dependencies in a cacheable layer.
COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile

# Generate the Prisma client at build time (the runtime schema comes from the mounted volume).
COPY prisma ./prisma
RUN pnpm exec prisma generate

EXPOSE 8990

# Overridden by the `command` in docker-compose (db push + dev).
CMD ["pnpm", "dev"]
